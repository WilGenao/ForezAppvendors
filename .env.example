# ============================================================
# ForexBot Marketplace — Variables de Entorno
# NUNCA commitear el .env real. Solo este .env.example
# Generar secrets: openssl rand -hex 32
# ============================================================

# ==================== POSTGRES ====================
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_USER=forexbot
POSTGRES_DB=forexbot

# ==================== REDIS ====================
REDIS_PASSWORD=change_me_redis_password

# ==================== JWT ====================
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==================== STRIPE ====================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==================== URLS ====================
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ==================== INTERNAL SERVICES ====================
# FIX NEW: Shared secret between NestJS API and Analytics Engine
# Prevents direct access to the analytics service bypassing auth
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# ==================== SSL (Production only) ====================
# Set to "true" in production to enable SSL certificate verification for PostgreSQL
DB_SSL=false

# ==================== ENVIRONMENT ====================
NODE_ENV=development
