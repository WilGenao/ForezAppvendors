# ==================== API Config ====================
NODE_ENV=development
PORT=3001

# ==================== Database (inyectado por Docker Compose) ====================
DATABASE_URL=postgresql://forexbot:password@postgres:5432/forexbot

# ==================== Redis ====================
REDIS_URL=redis://:password@redis:6379

# ==================== JWT — Secretos reales, mínimo 64 chars aleatorios ====================
# Generar con: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==================== Stripe — Del dashboard de Stripe ====================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==================== Frontend URL ====================
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ==================== Analytics Engine ====================
ANALYTICS_ENGINE_URL=http://analytics:8000

# ==================== Azure Blob (para documentos KYC) ====================
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
AZURE_STORAGE_CONTAINER=kyc-documents
