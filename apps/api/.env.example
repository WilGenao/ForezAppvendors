# ============================================================
# ForexBot API — Environment Variables
# Copy to .env and fill in all values before running.
# NEVER commit .env to git. Only this .env.example file.
# ============================================================

# ==================== SERVER ====================
NODE_ENV=development
PORT=3001

# ==================== DATABASE ====================
DATABASE_URL=postgresql://forexbot:CHANGE_ME@localhost:5432/forexbot

# ==================== REDIS ====================
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ==================== JWT ====================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_64_chars_minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_64_chars_minimum_different_from_access
JWT_REFRESH_EXPIRES_IN=7d

# ==================== STRIPE ====================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
# Get from https://dashboard.stripe.com/webhooks after creating webhook endpoint
# Webhook endpoint: POST /api/v1/payments/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME

# ==================== AZURE BLOB ====================
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=CHANGE_ME;AccountKey=CHANGE_ME;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_KYC=kyc-documents
AZURE_STORAGE_CONTAINER_BOTS=bot-assets

# ==================== CORS ====================
# FIX: This is now REQUIRED (no default). Set to your frontend URL.
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
